# 数据库（Zeabur PostgreSQL 自动注入）
DATABASE_URL="postgresql://user:pass@host:5432/db"

# 管理后台密码
ADMIN_PASSWORD="your-admin-password"

# 轮询配置
CHECK_POLL_INTERVAL=60          # 检查间隔（秒），范围 10-3600
CHECK_CONCURRENCY=5             # 并发数，范围 1-20
HISTORY_RETENTION_DAYS=30       # 历史数据保留天数，范围 1-365

# 多实例部署时，只在一个实例上启动轮询器
# ENABLE_POLLER=false           # 设为 false 可禁用当前实例的轮询
